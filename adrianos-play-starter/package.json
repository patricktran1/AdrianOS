{
  "name": "adrianos-play",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:games": "node scripts/generate-games.mjs",
    "dev": "npm run generate:games && next dev",
    "build": "npm run generate:games && npm run check:contracts && next build",
    "start": "next start",
    "test:unit": "node --test test/unit/*.test.mjs",
    "test:coverage": "node scripts/run-unit-coverage.mjs",
    "test:games": "playwright test",
    "test:games:smoke": "playwright test tests/e2e/game-routes.spec.ts",
    "test:games:completion": "playwright test tests/e2e/game-completion.spec.ts",
    "validate": "npm run test:unit && npm run build",
    "check:contracts": "npm run check:school-controls && npm run check:game-session && npm run check:curriculum && npm run check:teaching-loop && npm run check:blank-slate && npm run check:mastery-loop && npm run check:elementary-scope",
    "check:school-controls": "node scripts/check-school-mode-controls.mjs",
    "check:game-session": "node scripts/check-game-session-sdk.mjs",
    "check:curriculum": "node scripts/check-curriculum-map.mjs",
    "check:teaching-loop": "node scripts/check-teaching-loop.mjs",
    "check:blank-slate": "node scripts/check-blank-slate-personalization.mjs",
    "check:mastery-loop": "node scripts/check-mastery-loop.mjs",
    "check:elementary-scope": "node scripts/check-elementary-scope.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "next": "^16.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.9.0"
  },
  "overrides": {
    "postcss": "8.5.22",
    "sharp": "0.35.3"
  }
}
